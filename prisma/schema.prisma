// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  PRO
  LEGACY
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  categories        Category[]
  accounts          Account[]
  sessions          Session[]
  financialAccounts FinancialAccount[]
  bankConnections   BankConnection[]
  transactions      Transaction[]

  // Freemium + onboarding
  plan             PlanTier @default(FREE)
  onboarded        Boolean  @default(false)
  role             Role     @default(USER)
  stripeCustomerId String?

  // Onboarding details
  age             Int?
  country         String?
  primaryCurrency String?
  discovery       String?
  experienceLevel String?
  primaryGoal     String?
  netWorth        Float?
  expectations    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  name      String
  icon      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  type      String
  isActive  Boolean  @default(true)

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Transaction Transaction[]

  @@unique([name, userId])
  @@index([userId])
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum FinancialAccountType {
  CASH
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
}

model FinancialAccount {
  id                String               @id @default(auto()) @map("_id") @db.ObjectId
  userId            String               @db.ObjectId
  name              String
  type              FinancialAccountType
  currency          String
  balance           Float                @default(0)
  institutionName   String?
  institutionLogo   String?
  icon              String? // Custom icon for manual accounts
  color             String? // Custom color for manual accounts  
  provider          String               @default("manual") // manual | gocardless
  externalAccountId String?
  connectionId      String?
  isArchived        Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  linked            Boolean              @default(false)

  // API rate limiting and sync tracking fields
  apiCallsToday       Int       @default(0)
  lastApiCallAt       DateTime?
  lastSyncedAt        DateTime?
  nextSyncAvailableAt DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId, isArchived])
  @@index([lastApiCallAt])
  @@index([nextSyncAvailableAt])
}

model Transaction {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                String    @db.ObjectId
  accountId             String    @db.ObjectId
  externalTransactionId String? // GoCardless transaction ID
  amount                Float
  currency              String
  description           String?
  type                  String?
  categoryId            String?   @db.ObjectId
  merchantName          String?
  date                  DateTime
  bookingDate           DateTime?
  valueDate             DateTime?
  provider              String    @default("manual") // manual | gocardless
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?        @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([externalTransactionId, provider])
  @@index([userId, accountId])
  @@index([userId, date])
}

model BankConnection {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  userId               String   @db.ObjectId
  provider             String   @default("gocardless")
  requisitionId        String
  status               String   @default("PENDING")
  institutionId        String
  institutionName      String?
  transactionTotalDays Int? // Maximum days of transaction history available from this institution
  reference            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
